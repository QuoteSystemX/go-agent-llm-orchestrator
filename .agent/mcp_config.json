{
    "mcpServers": {
        "skills": {
            "command": "sh",
            "args": ["-c", "exec $(git rev-parse --show-toplevel)/.agent/skill-server/skill-server.sh"],
            "description": "Antigravity Kit skill loader — exposes skills_load, skills_list, skills_search"
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        }
    }
}
