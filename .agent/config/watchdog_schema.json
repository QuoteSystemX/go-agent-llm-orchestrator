{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Watchdog Rules Schema",
  "type": "object",
  "properties": {
    "limits": {
      "type": "object",
      "properties": {
        "token_budget_per_task": { "type": "integer", "minimum": 0 },
        "cost_limit_per_task_usd": { "type": "number", "minimum": 0 }
      }
    },
    "dangerous_operations": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "object",
          "properties": {
            "block": { "type": "array", "items": { "type": "string" } },
            "warn": { "type": "array", "items": { "type": "string" } }
          }
        },
        "files": {
          "type": "object",
          "properties": {
            "protected": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
