{
    "_readme": "Template config for Antigravity (Gemini). Copy to your Antigravity workspace and replace YOUR_API_KEY placeholders. The 'skills' server is required; 'context7' and 'shadcn' are optional extras.",
    "mcpServers": {
        "local-skill-server": {
            "command": "/usr/bin/env",
            "args": ["agent-kit-server"]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "wikipedia": {
            "command": "npx",
            "args": [
                "-y",
                "wikipedia-mcp"
            ]
        },
        "filesystem": {
            "command": "sh",
            "args": [
                "-c",
                "npx -y @modelcontextprotocol/server-filesystem $(pwd)"
            ]
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ]
        },
        "browser": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ]
        }
    }
}